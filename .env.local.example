# App
NEXT_PUBLIC_SITE_URL=https://www.aimpacttechnology.com

# Anthropic (chat widget)
ANTHROPIC_API_KEY=sk-ant-...

# n8n
N8N_CONTACT_WEBHOOK_URL=https://aimpacttechnology.app.n8n.cloud/webhook/website-contact
